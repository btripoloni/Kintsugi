{
  "tasks": {
    "cli": "deno run -A ./src/cli/main.ts",
    "dev": "deno run -A --watch ./src/cli/main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 4,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
