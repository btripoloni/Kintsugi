{
  "tasks": {
    "cli": "deno run -A ./src/cli/main.tsx",
    "dev": "deno run -A --watch ./src/cli/main.tsx"
  },
  "imports": {
    "react": "npm:react@^18.3.1",
    "react/jsx-runtime": "npm:react@^18.3.1/jsx-runtime",
    "react-dom/client": "npm:react-dom@^18.3.1/client",
    "react-dom": "npm:react-dom@^18.3.1",
    "ink": "jsr:@deno-ink/core@^0.2.1",
    "@std/assert": "jsr:@std/assert@1"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["npm:@types/react"]
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 4,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
