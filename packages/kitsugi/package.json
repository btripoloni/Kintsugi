{
  "name": "kitsugi",
  "version": "0.1.0",
  "description": "TypeScript library for declarative Kintsugi modlist management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "lint": "echo \"No lint configured\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  }
}
