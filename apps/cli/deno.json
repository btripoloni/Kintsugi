{
  "name": "@btripoloni/kintsugi-cli",
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run -A --watch src/main.ts",
    "start": "deno run -A src/main.ts",
    "build": "deno compile -A -o ../../dist/kintsugi src/main.ts"
  },
  "imports": {
    "@btripoloni/kintsugi": "jsr:@btripoloni/kintsugi",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@std/fs": "jsr:@std/fs@1"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.window"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 4,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
